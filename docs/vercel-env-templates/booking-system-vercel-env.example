# Public app config
NEXT_PUBLIC_APP_URL=https://booking-system-self-five.vercel.app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_SUPABASE_ANON_KEY_HERE

# Server-only Supabase
SUPABASE_SERVICE_ROLE_KEY=PASTE_SUPABASE_SERVICE_ROLE_KEY_HERE

# App identity
APP_TIMEZONE=Asia/Kuala_Lumpur
APP_NAME=Booking System
COMPANY_NAME=YOUR_COMPANY_NAME
SYSTEM_CONTACT_EMAIL=YOUR_CONTACT_EMAIL

# Email provider
EMAIL_PROVIDER=smtp
EMAIL_FROM=Booking System <noreply@yourcompany.com>
EMAIL_API_KEY=

# Microsoft 365 SMTP
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=noreply@yourcompany.com
SMTP_PASSWORD=PASTE_MICROSOFT_365_MAILBOX_PASSWORD_OR_APP_PASSWORD_HERE

# Microsoft 365 Calendar sync disabled until IT setup is ready
CALENDAR_SYNC_PROVIDER=disabled
MICROSOFT_365_CALENDAR_SYNC_ENABLED=false
MICROSOFT_SYNC_MODE=disabled
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_DEFAULT_CALENDAR_ID=
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# n8n webhook calendar sync. Configure create only for testing, or all three
# webhook URLs for full lifecycle create/update/delete sync.
N8N_CALENDAR_SYNC_ENABLED=false
N8N_CALENDAR_CREATE_WEBHOOK_URL=
N8N_CALENDAR_UPDATE_WEBHOOK_URL=
N8N_CALENDAR_DELETE_WEBHOOK_URL=
N8N_CALENDAR_WEBHOOK_SECRET=
