# NEXT_PUBLIC_* values are safe for browser usage and may be bundled into
# client-side JavaScript by Next.js. In production, NEXT_PUBLIC_APP_URL must
# be the canonical HTTPS URL configured in Vercel and Supabase Auth.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# If using Microsoft login through Supabase Auth, enable the Azure provider in
# Supabase and add {NEXT_PUBLIC_APP_URL}/auth/callback as an allowed redirect URL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only configuration.
#
# SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security and must never be
# imported, logged, exposed, or used in client components.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only secret used to authorize protected cron route handlers.
# Set this to a long random value in Vercel and send it as:
# Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=

# Server-only email provider settings.
#
# EMAIL_PROVIDER can be blank, "none", "resend", or "smtp". Leave blank
# locally to keep email processing safe; queued emails will fail with a clear
# configuration message instead of crashing the app.
#
# EMAIL_API_KEY is used by Resend. SMTP_* values are used by the SMTP provider.
# EMAIL_API_KEY and SMTP_PASSWORD must never be exposed to client components or
# NEXT_PUBLIC_* variables.
#
# EMAIL_FROM should be a verified sender or domain in the chosen provider.
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=

# SMTP provider settings. For Microsoft 365, common values are:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_USER=noreply-or-service-mailbox@company.com
# SMTP_PASSWORD=mailbox-password-or-app-password
#
# For Brevo SMTP, use smtp-relay.brevo.com on port 587 with
# SMTP_SECURE=false and SMTP_REQUIRE_TLS=true. SMTP_PASSWORD must be a Brevo
# SMTP key, not a Brevo API key or account password.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_REQUIRE_TLS=
SMTP_USER=
SMTP_PASSWORD=

# Microsoft 365 Calendar sync groundwork. This is for future one-way
# Booking System -> Microsoft 365 Calendar sync through Microsoft Graph, not
# SMTP email delivery. Keep client ID/secret server-only and do not prefix
# these values with NEXT_PUBLIC_.
CALENDAR_SYNC_PROVIDER=disabled
MICROSOFT_365_CALENDAR_SYNC_ENABLED=false
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_DEFAULT_CALENDAR_ID=
# Use central_calendar to write to MICROSOFT_DEFAULT_CALENDAR_ID, or
# booking_owner_calendar to write to each booking owner's company mailbox.
MICROSOFT_SYNC_MODE=disabled
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# n8n webhook calendar sync provider. Configure create only for safe testing,
# or create/update/delete for full lifecycle sync. The webhook secret is sent
# only as an x-booking-system-secret header.
N8N_CALENDAR_SYNC_ENABLED=false
N8N_CALENDAR_CREATE_WEBHOOK_URL=
N8N_CALENDAR_UPDATE_WEBHOOK_URL=
N8N_CALENDAR_DELETE_WEBHOOK_URL=
N8N_CALENDAR_WEBHOOK_SECRET=

# Application defaults. These are server-side defaults and may also be
# represented in system_settings where runtime configurability is needed.
APP_TIMEZONE=Asia/Kuala_Lumpur
APP_NAME=Booking System
COMPANY_NAME=
SYSTEM_CONTACT_EMAIL=

# Optional Playwright E2E settings. Use dedicated test users and never commit
# real credentials. E2E_BASE_URL defaults to http://localhost:3000 when blank.
E2E_BASE_URL=
E2E_EMPLOYEE_EMAIL=
E2E_EMPLOYEE_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_SUPER_ADMIN_EMAIL=
E2E_SUPER_ADMIN_PASSWORD=
E2E_USE_PRODUCTION=false
